# Development environment
NODE_ENV=development

# Database - SQLite for local development (switch to PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth - development secret
NEXTAUTH_SECRET="dev-secret-change-in-production-12345"
NEXTAUTH_URL="http://localhost:3000"

# Feature flags
ENABLE_AI_INSIGHTS=true
ENABLE_CRYPTO=true
ENABLE_PORTFOLIO_SIMULATOR=true

# AI Provider - use mock for development
AI_PROVIDER=mock
