# Development environment
NODE_ENV=development

# Database - use a local PostgreSQL or placeholder for development
DATABASE_URL="postgresql://localhost:5432/ai_portfolio"
DIRECT_URL="postgresql://localhost:5432/ai_portfolio"

# NextAuth - development secret
NEXTAUTH_SECRET="dev-secret-change-in-production-12345"
NEXTAUTH_URL="http://localhost:3000"

# Feature flags
ENABLE_AI_INSIGHTS=true
ENABLE_CRYPTO=true
ENABLE_PORTFOLIO_SIMULATOR=true

# AI Provider - use mock for development
AI_PROVIDER=mock
